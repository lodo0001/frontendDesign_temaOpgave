---
import { Image } from "astro:assets";
import Services from "./Services.astro";
import CEOImage from "@assets/images/ceo.webp";
---

<section class="hero">
  <div class="hero-content">
    <div>
      <h1>Empowering Your Business Growth</h1>
      <p>
        Discover tailored strategies and expert insights to take your business
        to the next level. Let us help you navigate challenges and achieve
        sustainable success.
      </p>
      <a href="#0">Book a Meeting</a>
      <a href="#0">Learn More</a>
    </div>
    <div class="image-wrapper">
      <Image src={CEOImage} alt="CEO" />
    </div>
  </div>
  <article>
    <Services />
  </article>
</section>

<style>
  /* Styles her */
  @layer components {
    .hero {
      background-color: #f3f4f6;
      padding: 5rem;
      overflow: hidden;
      display: grid;
      grid-template-columns:
        [full-start] 1fr [content-start] minmax(0, 600px),
        minmax(0, 600px) [content-end] 1fr [full-end];
      grid-template-rows: auto 1fr 1fr;
      --grid-color: hsl(from #ffcc4a h s l / 0.18);
      --grid-size: 60px;
      background:
        radial-gradient(circle at 90% 50%, black, #0000, #000),
        conic-gradient(
            from 180deg at 1px 1px,
            var(--grid-color) 75%,
            #0000 0
          ) -1px -1px /
          var(--grid-size) var(--grid-size),
        #000;
      color: #fff;
    }

    .hero-content {
      grid-column: content-start;
      grid-row: 1;
      justify-content: space-between;
    }

    .image-wrapper {
      grid-column: content-end / full-end;
      grid-row: 1;
    }

    h1 {
      font-size: 40px;
    }
  }
</style>
