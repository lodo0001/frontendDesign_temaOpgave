---
import Phone from "@icons/phone.svg";
import Clock from "@icons/clock.svg";
import Pin from "@icons/pin.svg";
---

<section class="contact">
  <div class="contact-inner">
    <div class="contact-text">
      <span>PROCESS</span>
      <h3>Contact Us. It’s Easy.</h3>
      <p>
        Leverage agile frameworks to provide a robust synopsis for high level
        overviews. Iterative approaches to corporate strategy foster
        collaborative.
      </p>

      <ul class="contact-list">
        <li>
          <div class="icon-circle phone-bg">
            <Phone class="phone_icon" />
          </div>
          <span> Call Today </span>
          <p>+1 800 100 900</p>
        </li>

        <li>
          <div class="icon-circle clock-bg">
            <Clock class="clock_icon" />
          </div>
          <span> Monday To Friday </span>
          <p>9AM - 5PM</p>
        </li>

        <li>
          <div class="icon-circle pin-bg">
            <Pin class="pin_icon" />
          </div>
          <span> USA Office </span>
          <p>195 Devonshire St Boston, MA 02110</p>
        </li>
      </ul>
    </div>
    <article class="img_grid">
      <figure class="firkant/img">
        <img src="src/assets/images/contact_1.webp" alt="img_1" />
      </figure>
      <img src="src/assets/images/contact_2.webp" alt="img_2" />
      <img src="src/assets/images/contact_3.webp" alt="img_3" />
    </article>
  </div>
</section>

<style>
  @layer components {
    .contact {
      grid-column: full-start / full-end;
      display: grid;
      grid-template-columns: subgrid;
      padding: 80px 0;
    }

    .contact-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 80px;
      align-items: start;
    }

    /* css til den grønne firkant og dens grønne firkant */
    .img_grid img {
      border-radius: 20px;
      width: 100%;
    }

    figure {
      margin-inline: auto;
      max-width: 600px;
      margin: 1rem;
      display: block;
      position: relative;

      &::before {
        content: "";
        position: absolute;
        top: 250px;
        left: -40px;
        background: var(--color-green-400);
        border-radius: 20px;
        width: 190px;
        height: 120px;
        z-index: -1;
      }
    }

    /* css til img_grid */
    .img_grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      column-gap: 1em;
      row-gap: 1em;

      :first-child {
        grid-column: 1/2;
        grid-row: 1/3;
      }

      :nth-child(2) {
        grid-column: 2/3;
        grid-row: 1/2;
      }

      :nth-child(3) {
        grid-column: 2/3;
        grid-row: 2/3;
      }
    }

    /* css til text sektionen */
    /* Herunder bruges supports not, det bruges til at se om browseren undersøttet text-box, 
    hvis ikke, så bruger der vores supports not, altså margin-top */
    .contact-text h3 {
      text-box: trim-both cap alphabetic;

      @supports not (text-box-trim: trim-both) {
        margin-top: calc(0.5cap - 0.5lh);
      }
      font-size: 35px;
      font-weight: bold;
      margin: 10px 0 20px;
    }

    .contact-list {
      list-style: none;
      padding: 0;
      margin-top: 24px;
      display: grid;
      gap: 16px;
    }

    .contact-list li {
      display: flex;
      align-items: flex-start;
      gap: 20px;
    }

    .contact-list span {
      font-size: 12px;
    }

    /* css til ikoner */
    .icon-circle {
      width: 48px;
      height: 48px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .phone-bg {
      background-color: #ffecbb;
      color: var(--color-yellow-500);
    }

    .clock-bg {
      background-color: var(--color-green-400);
      color: var(--color-green-600);
    }

    .pin-bg {
      background-color: var(--color-neutrals-200);
    }
  }
</style>
