---
import faqData from "@data/faq.json";
---

<section class="faq_section">
  <div class="faq_content">
    <div class="faq_text">
      <p>FAQ</p>
      <h2>Customer Questions</h2>
    </div>
    <div class="faq_container">
      {
        faqData.faq.map(({ question, answer }) => (
          <details name="faq">
            <summary>{question}</summary>
            <div class="content">
              <p class="faq-answer">{answer}</p>
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>

<style>
  @layer components {
    .faq_section {
      display: grid;
      grid-template-columns: min(100%, 65ch);
      place-content: center;
      gap: 2rem;
      margin: 200px;
    }

    .faq_content {
      background-color: var(--color-neutrals-50);
      padding: 50px;
      border-radius: 20px;
    }

    .faq_text {
      text-align: center;
    }

    .faq_container {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      width: 100%;
    }

    summary {
      cursor: pointer;
      padding: 1rem;
      display: flex;
      gap: 1rem;
      align-items: center;
      justify-content: space-between;
    }

    details {
      border-bottom: 0.5px solid var(--color-neutrals-400);
    }

    .content {
      padding: 1rem;

      p {
        margin: 0;
      }
    }

    ::marker {
      content: none;
    }

    summary::after {
      content: "+";
      font-family: system-ui;
      font-weight: 400;
      font-size: 1.1rem;
    }

    [open] summary::after {
      content: "–";
    }

    ::details-content {
      height: 0;
      overflow: clip;
      transition: 0.3s allow-discrete;
    }

    details[open]::details-content {
      height: auto;
    }
  }
</style>
