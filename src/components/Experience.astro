---
import experience from "@data/experience.json";
---

<section class="experience">
  <div class="experience-inner">
    <article class="experience-text">
      <span>{experience.eyebrow}</span>
      <h3>{experience.title}</h3>
      <p>{experience.subtitle}</p>
    </article>

    <article class="stats">
      {
        experience.stats.map((stat) => (
          <div class="stat">
            <div class="circle" style={`--value:${stat.value}`} />
            <p>{stat.label}</p>
          </div>
        ))
      }
    </article>
  </div>
</section>

<style>
  @layer components {
    .experience {
      grid-column: full-start / full-end;
      display: grid;
      grid-template-columns: subgrid;
      padding: 100px 0;

      background-color: var(--color-yellow-500);
    }

    .experience-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      align-items: start;

      h3 {
        line-height: 3rem;
      }
    }

    .experience-text {
      display: flex;
      flex-direction: column;
      gap: var(--space-xs);
    }

    .stats {
      display: flex;
      gap: 2rem;
    }

    .stat {
      aspect-ratio: 1;
      min-width: 0;

      display: grid;
      justify-items: center;
      gap: 10px;

      position: relative;

      p {
        font-size: var(--p);
        font-weight: bolders;
        font-family: var(--font-lato);
      }
    }

    /* css til cirklerne */
    @property --animatedNumber {
      syntax: "<number>";
      initial-value: 0;
      inherits: true;
    }

    .circle {
      --animatedNumber: var(--value);
      --percentage: calc(var(--animatedNumber) * 1%);
      --bd: 6px;

      width: 160px;
      aspect-ratio: 1;

      position: relative;
      border-radius: 999px;

      border: var(--bd) solid transparent;

      background:
        radial-gradient(
            circle at 50% calc(var(--bd) / 2),
            #0f172a calc(var(--bd) / 2),
            transparent 0
          )
          border-box,
        linear-gradient(var(--color-yellow-500)) padding-box,
        conic-gradient(white var(--percentage), rgba(255, 255, 255, 0.3) 0)
          border-box;

      display: grid;
      place-items: center;

      &:hover {
        --animatedNumber: 100;
      }

      transition: --animatedNumber 2s ease;
    }

    .circle::after {
      counter-reset: val round(var(--animatedNumber));
      content: counter(val) "%";

      font-size: 40px;
      font-weight: 800;

      font-variant-numeric: tabular-nums;
    }

    .circle::before {
      content: "";

      position: absolute;

      width: 18px;
      aspect-ratio: 1;

      border-radius: 50%;

      background: #0f172a;
      border: 4px solid white;

      offset: border-box var(--percentage);
      offset-anchor: 50% calc(50% - var(--bd) / 2);
    }

    @media (max-width: 1024px) {
      .experience-inner {
        grid-template-columns: 1fr;
        row-gap: 2rem;
        justify-items: center;
        padding-inline: 12.5rem;
        text-align: center; /* centrer teksten */
      }

      .stats {
        flex-direction: row;
      }

      .circle {
        width: 120px;
      }

      .circle::after {
        font-size: 28px;
      }
      .core_btn {
        align-self: center; /* centrer knappen på mobil */
        margin: 9rem;
      }
    }
  }
</style>
