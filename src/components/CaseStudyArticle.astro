---
//@ts-nocheck
import DynamicImage from "@components/helpers/DynamicImage.astro";
import caseStudy from "@data/caseStudy.json";
const { caseName, category, date, image, buttonLabel } = caseStudy.caseDetails;
---

<article>
  <header>
    <DynamicImage imagePath={image} altText={caseName} />
    <div class="case-details">
      <dl>
        <div>
          <dt>Case Name</dt>
          <dd>{caseName}</dd>
        </div>
        <div>
          <dt>Category</dt>
          <dd class="category">{category}</dd>
        </div>
        <div>
          <dt>Date</dt>
          <dd class="date">{date}</dd>
        </div>
      </dl>
      <a href="#0" class="button">{buttonLabel}</a>
    </div>
  </header>
  {
    caseStudy.sections.map((section) => (
      <section class="caseStudy_text">
        {caseStudy.sections[0] === section ? (
          <h2>{section.title}</h2>
        ) : (
          <h3>{section.title}</h3>
        )}

        {Array.isArray(section.content) ? (
          <>
            {section.content.map((item) => (
              <p>{item}</p>
            ))}
          </>
        ) : (
          <p>{section.content}</p>
        )}
        {section.highlights && (
          <ul>
            {section.highlights.map((highlight) => (
              <li>{highlight}</li>
            ))}
          </ul>
        )}
        {section.image && (
          <DynamicImage
            imagePath={section.image}
            altText={section.title}
            width={600}
            height={400}
          />
        )}
      </section>
    ))
  }
</article>

<style>
  @layer components {
    article {
      grid-column: full-start / full-end;
      display: grid;
      grid-template-columns: subgrid;
      padding: 80px 0px;
    }

    /* Css til billedet + det sorte */
    header {
      position: relative;
      margin-bottom: 130px;

      img {
        width: 100%;
        border-radius: 20px;
        display: block;
      }
    }

    .case-details {
      position: absolute;
      left: 50%;
      bottom: -60px;
      transform: translateX(-50%);

      width: 90%;
      max-width: 1000px;

      background-color: var(--color-neutrals-900);
      color: white;

      border-radius: 24px;
      padding: 2rem 2.5rem;

      display: grid;
      grid-template-columns: 1fr auto;
      align-items: center;

      dl {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
        margin: 0;
      }

      dt {
        font-size: var(--p);
        font-weight: 500;
        margin-bottom: 0.1rem;
      }
    }

    .button {
      background-color: var(--color-yellow-500);
      color: black;

      padding: 0.75rem 1.5rem;
      border-radius: 999px;

      text-decoration: none;
      font-weight: 500;

      white-space: normal;
    }

    /* Css til tekst-afsnittet */
    .caseStudy_text {
      grid-column: content-start / content-end;
      line-height: 1.6;
      padding-inline: 11rem;

      & > * + * {
        margin-block-start: var(--flow-space, 1rem);
      }

      h2 {
        font-size: var(--h4);
        + * {
          --flow-space: 1rem;
        }
      }

      h3 {
        margin-top: 1.5rem;
        font-size: var(--h5);

        + * {
          --flow-space: 1rem;
        }
      }

      img {
        margin-block: 2rem;
        display: block;
        margin-inline: auto;
      }
    }
    @media (max-width: 1024px) {
      header {
        margin-bottom: 70px;
        padding-inline: 2rem;
      }

      .case-details {
        position: static;
        transform: none;
        display: flex;

        width: 100%;
        grid-template-columns: 2fr; /* stack indhold */
        gap: 1.5rem;
      }

      .button {
        margin-inline: auto;
      }

      .caseStudy_text {
        padding-inline: 3rem;
      }

      .case-details dl {
        grid-template-columns: 1fr;
      }
    }
  }
</style>
