---
import Cal from "@icons/cal.svg";
import Card from "@icons/card.svg";
import Law from "@icons/law.svg";
import Money from "@icons/money.svg";
import ArrowRight from "@icons/arrow--right.svg";
import ArrowLeft from "@icons/arrow-left.svg";
---

<main>
  <section class="full">
    <header>
      <div class="financial_text">
        <span class="tools">FINANCIAL TOOLS</span>
        <h2>Financial Projections</h2>
        <p>
          Financial projections are essential for planning and monitoring a
          company’s performance. They provide insights into potential revenue,
          expenses, and profitability over specific periods.
        </p>
      </div>
      <div class="arrows_buttons">
        <button class="arrowLeft"><ArrowLeft /></button>
        <button class="arrowRight"><ArrowRight /></button>
      </div>
    </header>

    <ul role="list">
      <li>
        <Cal class="icons" />
        <h3>The Balance Sheet</h3>
        <p>
          The Balance Sheet is a summary of the assets and liabilities and
          equity of a business at a specific point of time.
        </p>
      </li>

      <li>
        <Card class="icons" />
        <h3>Income Statement</h3>
        <p>
          The Income (Profit and Loss) Statement, commonly referred to as the
          P&L statement, summarizes the revenue and expenses for a specific time
          period (one month, one quarter, one year, etc.)
        </p>
      </li>

      <li>
        <Law class="icons" />
        <h3>Financial Plan</h3>
        <p>
          Keep your information current and review the documents on a regular
          basis (monthly or more often if needed). Review them with key
          individuals within your company.
        </p>
      </li>

      <li>
        <Money class="icons" />
        <h3>Financial Ratios</h3>
        <p>
          Ratios are useful when comparing your company with the competition on
          financial performance and also when benchmarking the performance of
          your company.
        </p>
      </li>
    </ul>
  </section>
</main>

<style>
  :root {
    --content-width: 50rem;
  }

  main {
    padding-block: 4rem;
    grid-column: full-start / full-end;
    display: grid;
    grid-template-columns: subgrid;
    background-color: var(--color-neutrals-50);
    padding: 80px 0;

    > * {
      grid-column: content;
    }

    .full {
      grid-column: full;
      display: grid;
      grid-template-columns: inherit;
      row-gap: 4rem;

      > * {
        grid-column: content;
      }

      > ul {
        scroll-snap-type: x mandatory;
        grid-column: full;
        padding-inline: max(1rem, 50% - var(--content-width) / 1.45);
        padding-block-end: 1rem;

        li {
          scroll-snap-align: center;
        }
      }
    }
  }

  ul {
    display: flex;
    gap: 2rem;
    overflow-x: auto;

    li {
      flex-basis: min(400px, 90%);
      flex-shrink: 0;
      background: #ebebeb;
      color: #595566;
      border-radius: 8px;
      font-size: 1rem;
      padding: 2.75rem 2.1875rem;
      align-self: start;
      font-family: var(--font-lato);

      h3 {
        font-weight: 700;
        font-size: 1.5625rem;
      }
    }
  }

  h2,
  h3 {
    color: #181818;
    margin-block: 0 0.625rem;
  }

  h2 {
    font-size: var(--h2);
  }

  header {
    color: #595566;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;

    p {
      max-inline-size: 67ch;
      font-family: var(--font-lato);
    }
  }

  .header_text {
    max-width: 600px;
  }

  /* Css til icons */
  .icons {
    color: black;
    padding-bottom: 1rem;
  }

  .arrows_buttons {
    display: flex;
    gap: 20px;
    align-self: end;
  }

  .arrowRight,
  .arrowLeft {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    border: none;
    color: var(--color-neutrals-50);
    background-color: var(--color-neutrals-900);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }

  .arrowRight:hover,
  .arrowLeft:hover {
    background: oklch(from var(--color-neutrals-900) calc(l + 0.1) c h);
  }

  .arrowRight:active,
  .arrowLeft:active {
    background: oklch(from var(--color-neutrals-900) calc(l + 0.2) c h);
  }

  /* Responsiv */
  @media (max-width: 1024px) {
    .full > ul {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.5rem;
      padding-inline: 1rem;
      overflow-x: visible;
      justify-items: center;
    }

    ul li {
      padding: 1.5rem 1rem;
      max-width: 600px;
      width: 100%;
    }

    .icons {
      width: 24px;
      height: 24px;
      padding-bottom: 0.5rem;
    }

    header p {
      max-inline-size: 100%;
      text-align: center;
      padding-inline: 9rem;
    }

    header h2 {
      text-align: center;
    }

    header .tools {
      display: block;
      text-align: center;
      margin-bottom: 0.5rem;
      font-size: 0.85rem;
    }

    .arrows_buttons {
      display: none;
    }
  }
</style>

