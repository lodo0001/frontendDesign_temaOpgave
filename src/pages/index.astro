---
import Layout from "@layouts/Layout.astro";
import Navbar from "@components/Navbar.astro";
import Hero from "@components/Hero.astro";
import Footer from "@components/Footer.astro";
import Newsletter from "@components/Newsletter.astro";
import Services from "@components/Services.astro";
import WhatToExpect from "@components/WhatToExpect.astro";
import FinancialProjection from "@components/FinancialProjection.astro";
import Experience from "@components/Experience.astro";
import CoreValues from "@components/CoreValues.astro";
import ContactUs from "@components/ContactUs.astro";
---

<Layout>
  <Navbar />
  <Hero />
  <article class="services-content content">
    <Services />
  </article>
  <WhatToExpect />
  <FinancialProjection />
  <Experience />
  <CoreValues theme="dark" />
  <ContactUs />
  <Newsletter />
  <Footer />
</Layout>

<style>
  .services-content {
    grid-column: content-start / content-end;
    position: relative;
    z-index: 10;
    margin-top: -95px;
  }
</style>
